<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:PandasBudgettingTool.ViewModels"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="900" d:DesignHeight="600"
             x:Class="PandasBudgettingTool.Views.ImportStatementView"
             x:DataType="vm:ImportStatementViewModel">

    <Design.DataContext>
        <vm:ImportStatementViewModel/>
    </Design.DataContext>

    <Grid RowDefinitions="Auto,*" ColumnDefinitions="*,*,*" Margin="24">

        <StackPanel Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="3"
                    Spacing="8" MaxWidth="480" HorizontalAlignment="Left">

            <TextBlock Text="Import Account Statement" FontSize="20" FontWeight="SemiBold" Margin="0,0,0,12"/>

            <TextBlock Text="Account *"/>
            <ComboBox ItemsSource="{Binding AccountNames}"
                      SelectedItem="{Binding SelectedAccountName}"
                      PlaceholderText="Select an account…"
                      HorizontalAlignment="Stretch"/>

            <TextBlock Text="{Binding SelectedImporterTypeName}"
                       Foreground="{DynamicResource SystemControlForegroundBaseMediumLowBrush}"/>

            <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,12,0,0">
                <Button Content="Select Transaction Data" Command="{Binding SelectTransactionFileCommand}"/>
                <TextBlock Text="{Binding TransactionFilePath}" VerticalAlignment="Center" TextWrapping="Wrap"/>
            </StackPanel>

            <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,12,0,0">
                <Button Content="Import" Command="{Binding ImportCommand}" Width="80"/>
                <Button Content="Clear"  Command="{Binding ClearCommand}"  Width="80"/>
            </StackPanel>

            <TextBlock Text="{Binding StatusMessage}" Margin="0,8,0,0" TextWrapping="Wrap"/>

        </StackPanel>

        <TextBox Grid.Row="1" Grid.Column="0"
                  Text="{Binding HelpText}"
                  IsReadOnly="True"
                  TextWrapping="Wrap"
                  AcceptsReturn="True"
                  Margin="0,16,0,0"
                  VerticalAlignment="Stretch"
                  ScrollViewer.VerticalScrollBarVisibility="Auto"/>

    </Grid>

</UserControl>