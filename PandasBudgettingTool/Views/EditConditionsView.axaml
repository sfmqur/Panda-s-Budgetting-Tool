<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="PandasBudgettingTool.Views.EditConditionsView"
             x:CompileBindings="False">

    <DockPanel>

        <!-- Filter panel -->
        <Border DockPanel.Dock="Top"
                BorderBrush="{DynamicResource SystemBaseLowColor}"
                BorderThickness="0,0,0,1"
                Padding="8,6">
            <StackPanel Orientation="Horizontal" Spacing="8">
                <TextBlock Text="Filter by Rule:" VerticalAlignment="Center"/>
                <ComboBox ItemsSource="{Binding RuleFilterOptions}"
                          SelectedItem="{Binding SelectedRuleFilter}"
                          MinWidth="180"/>
            </StackPanel>
        </Border>

    <DataGrid ItemsSource="{Binding Conditions}"
              AutoGenerateColumns="False"
              CanUserResizeColumns="True"
              GridLinesVisibility="Horizontal"
              Margin="4">

        <DataGrid.Columns>
            <DataGridTextColumn Header="Id"
                                Binding="{Binding Id}"
                                IsReadOnly="True"
                                Width="150" />

            <DataGridTemplateColumn Header="Rule" Width="180">
                <DataGridTemplateColumn.CellTemplate>
                    <DataTemplate>
                        <TextBlock Text="{Binding RuleName}"
                                   VerticalAlignment="Center" Margin="12,0"/>
                    </DataTemplate>
                </DataGridTemplateColumn.CellTemplate>
                <DataGridTemplateColumn.CellEditingTemplate>
                    <DataTemplate>
                        <ComboBox ItemsSource="{Binding RuleNames}"
                                  SelectedItem="{Binding RuleName}"
                                  HorizontalAlignment="Stretch"/>
                    </DataTemplate>
                </DataGridTemplateColumn.CellEditingTemplate>
            </DataGridTemplateColumn>

            <DataGridTemplateColumn Header="Rank" Width="110">
                <DataGridTemplateColumn.CellTemplate>
                    <DataTemplate>
                        <NumericUpDown Value="{Binding Rank}"
                                       Minimum="0"
                                       Increment="1"
                                       FormatString="0"/>
                    </DataTemplate>
                </DataGridTemplateColumn.CellTemplate>
            </DataGridTemplateColumn>

            <DataGridTemplateColumn Header="And/Or" Width="100">
                <DataGridTemplateColumn.CellTemplate>
                    <DataTemplate>
                        <TextBlock Text="{Binding AndOr}"
                                   VerticalAlignment="Center" Margin="12,0"/>
                    </DataTemplate>
                </DataGridTemplateColumn.CellTemplate>
                <DataGridTemplateColumn.CellEditingTemplate>
                    <DataTemplate>
                        <ComboBox ItemsSource="{Binding AndOrOptions}"
                                  SelectedItem="{Binding AndOr}"
                                  HorizontalAlignment="Stretch"/>
                    </DataTemplate>
                </DataGridTemplateColumn.CellEditingTemplate>
            </DataGridTemplateColumn>

            <DataGridTemplateColumn Header="Transaction Property" Width="165">
                <DataGridTemplateColumn.CellTemplate>
                    <DataTemplate>
                        <TextBlock Text="{Binding TransactionProperty}"
                                   VerticalAlignment="Center" Margin="12,0"/>
                    </DataTemplate>
                </DataGridTemplateColumn.CellTemplate>
                <DataGridTemplateColumn.CellEditingTemplate>
                    <DataTemplate>
                        <ComboBox ItemsSource="{Binding TransactionProperties}"
                                  SelectedItem="{Binding TransactionProperty}"
                                  HorizontalAlignment="Stretch"/>
                    </DataTemplate>
                </DataGridTemplateColumn.CellEditingTemplate>
            </DataGridTemplateColumn>

            <DataGridCheckBoxColumn Header="Is String"
                                    Binding="{Binding IsStringProperty}"
                                    Width="95" />

            <DataGridTemplateColumn Header="Conditional" Width="200">
                <DataGridTemplateColumn.CellTemplate>
                    <DataTemplate>
                        <TextBlock Text="{Binding Conditional}"
                                   VerticalAlignment="Center" Margin="12,0"/>
                    </DataTemplate>
                </DataGridTemplateColumn.CellTemplate>
                <DataGridTemplateColumn.CellEditingTemplate>
                    <DataTemplate>
                        <ComboBox ItemsSource="{Binding ConditionalOptions}"
                                  SelectedItem="{Binding Conditional}"
                                  HorizontalAlignment="Stretch"/>
                    </DataTemplate>
                </DataGridTemplateColumn.CellEditingTemplate>
            </DataGridTemplateColumn>

            <DataGridTextColumn Header="Value"
                                Binding="{Binding Value}"
                                Width="300" />

            <DataGridTemplateColumn Header="" Width="100">
                <DataGridTemplateColumn.CellTemplate>
                    <DataTemplate>
                        <Button Content="Delete" Click="OnDeleteClick"/>
                    </DataTemplate>
                </DataGridTemplateColumn.CellTemplate>
            </DataGridTemplateColumn>
        </DataGrid.Columns>

    </DataGrid>

    </DockPanel>

</UserControl>