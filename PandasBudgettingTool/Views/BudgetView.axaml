<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:PandasBudgettingTool.ViewModels"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="1000" d:DesignHeight="600"
             x:Class="PandasBudgettingTool.Views.BudgetView"
             x:CompileBindings="False">

    <Design.DataContext>
        <vm:BudgetViewModel/>
    </Design.DataContext>

    <DockPanel>

        <!-- Header / filter panel -->
        <Border DockPanel.Dock="Top"
                BorderBrush="{DynamicResource SystemBaseLowColor}"
                BorderThickness="0,0,0,1"
                Padding="8,6">
            <StackPanel Orientation="Vertical" Spacing="6">

                <TextBlock TextWrapping="Wrap" MaxWidth="900">
                    <Run Text="Budget:" FontWeight="SemiBold"/>
                    <Run Text="the target you set for this category. minus is expense target  "/>
                    <Run Text="Children Budget:" FontWeight="SemiBold"/>
                    <Run Text="the sum of every sub-category's budget, recursively.  "/>
                    <Run Text="Total Budget:" FontWeight="SemiBold"/>
                    <Run Text="Budget + Children Budget — the full amount planned for this branch.  "/>
                    <Run Text="Avg Spend / 30d:" FontWeight="SemiBold"/>
                    <Run Text="actual spending on this category and its sub-categories over the date range below, normalized to a 30-day rate for comparison against Total Budget."/>
                </TextBlock>

                <StackPanel Orientation="Horizontal" Spacing="8">
                    <TextBlock Text="From:" VerticalAlignment="Center"/>
                    <CalendarDatePicker SelectedDate="{Binding FromDate}" Width="140"/>
                    <TextBlock Text="To:" VerticalAlignment="Center"/>
                    <CalendarDatePicker SelectedDate="{Binding ToDate}" Width="140"/>

                    <Button Content="Apply Filter" Command="{Binding ApplyFilterCommand}" VerticalAlignment="Center"
                            ToolTip.Tip="Saves current budget targets, then reloads and recomputes the figures below"/>
                    <Button Content="Save" Command="{Binding SaveCommand}" VerticalAlignment="Center"
                            ToolTip.Tip="Saves current budget targets"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- Target totals -->
        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Spacing="24" Margin="8,8,8,0">
            <StackPanel Orientation="Horizontal" Spacing="6">
                <TextBlock Text="Target Expenses:" FontWeight="SemiBold"/>
                <TextBlock Text="{Binding TotalExpenses, StringFormat={}{0:F2}}"/>
            </StackPanel>
            <StackPanel Orientation="Horizontal" Spacing="6">
                <TextBlock Text="Target Cash Flow:" FontWeight="SemiBold"/>
                <TextBlock Text="{Binding TotalCashFlow, StringFormat={}{0:F2}}"/>
            </StackPanel>
        </StackPanel>

        <!-- Column headers -->
        <Grid DockPanel.Dock="Top" ColumnDefinitions="260,160,160,160,20,160,110" Margin="8,8,8,0">
            <TextBlock Grid.Column="1" Text="Budget"          FontWeight="SemiBold" HorizontalAlignment="Right" Margin="0,0,10,0"/>
            <TextBlock Grid.Column="2" Text="Children Budget" FontWeight="SemiBold" HorizontalAlignment="Right" Margin="0,0,10,0"/>
            <TextBlock Grid.Column="3" Text="Total Budget"    FontWeight="SemiBold" HorizontalAlignment="Right" Margin="0,0,10,0"/>
            <TextBlock Grid.Column="5" Text="Avg Spend / 30d" FontWeight="SemiBold" HorizontalAlignment="Right"/>
        </Grid>

        <TreeView ItemsSource="{Binding RootNodes}" Margin="4">
            <TreeView.ItemTemplate>
                <TreeDataTemplate ItemsSource="{Binding Children}">
                    <Grid ColumnDefinitions="260,160,160,160,20,160,120">
                        <TextBlock Grid.Column="0" Text="{Binding Name}" VerticalAlignment="Center"/>

                        <NumericUpDown Grid.Column="1"
                                       Value="{Binding OwnBudgetTarget}"
                                       Increment="10"
                                       FormatString="F2"
                                       Width="160"/>

                        <TextBlock Grid.Column="2" Text="{Binding ChildrenBudgetSum, StringFormat={}{0:F2}}"
                                   VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,10,0"/>

                        <TextBlock Grid.Column="3" Text="{Binding TotalBudget, StringFormat={}{0:F2}}"
                                   FontWeight="SemiBold"
                                   VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,10,0"/>

                        <Rectangle Grid.Column="4" Width="1" Margin="8,2"
                                   Fill="{DynamicResource SystemControlForegroundBaseMediumLowBrush}"/>

                        <TextBlock Grid.Column="5" Text="{Binding AverageSpend, StringFormat={}{0:F2}}"
                                   VerticalAlignment="Center" HorizontalAlignment="Right"/>
                        <Button Grid.Column="6" Content="Transactions" Click="OnTransactionsClick" Margin="15,0,0,0"/>
                    </Grid>
                </TreeDataTemplate>
            </TreeView.ItemTemplate>
        </TreeView>

    </DockPanel>

</UserControl>