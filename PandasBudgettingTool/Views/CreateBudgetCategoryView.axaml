<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:PandasBudgettingTool.ViewModels"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="600" d:DesignHeight="450"
             x:Class="PandasBudgettingTool.Views.CreateBudgetCategoryView"
             x:DataType="vm:CreateBudgetCategoryViewModel">

    <ScrollViewer>
        <StackPanel Margin="24" Spacing="8" MaxWidth="480" HorizontalAlignment="Left">

            <TextBlock Text="Create Budget Category" FontSize="20" FontWeight="SemiBold" Margin="0,0,0,12"/>

            <TextBlock Text="Name *"/>
            <TextBox Text="{Binding Name}" PlaceholderText="Category name"/>

            <TextBlock Text="Parent Category (optional)" Margin="0,4,0,0"/>
            <ComboBox ItemsSource="{Binding ExistingCategories}"
                      SelectedItem="{Binding SelectedParent}"
                      PlaceholderText="— None —"
                      HorizontalAlignment="Stretch"/>

            <CheckBox IsChecked="{Binding IsExcludedFromSpendingTotal}"
                      Content="Exclude from spending total (e.g. transfers, savings)"
                      Margin="0,4,0,0"/>

            <TextBlock Text="Monthly Budget Target (optional)" Margin="0,4,0,0"/>
            <NumericUpDown Value="{Binding BudgetTarget}"
                           Minimum="0"
                           FormatString="F2"
                           PlaceholderText="No target"/>

            <CheckBox IsChecked="{Binding CreateAssociatedRule}"
                      Content="Create Associated Rule"
                      Margin="0,4,0,0"/>

            <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,20,0,0">
                <Button Content="Create" Command="{Binding CreateCommand}" Width="80"/>
                <Button Content="Clear"  Command="{Binding ClearCommand}"  Width="80"/>
            </StackPanel>

        </StackPanel>
    </ScrollViewer>
</UserControl>