<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:PandasBudgettingTool.ViewModels"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="PandasBudgettingTool.Views.TransactionsView"
             x:DataType="vm:TransactionsViewModel">

    <Design.DataContext>
        <vm:TransactionsViewModel/>
    </Design.DataContext>

    <Grid>
        <TextBlock Text="Transactions"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Center"
                   FontSize="24"
                   Foreground="{DynamicResource SystemControlForegroundBaseMediumLowBrush}"/>
    </Grid>
</UserControl>
