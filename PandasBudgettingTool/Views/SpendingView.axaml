<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:PandasBudgettingTool.ViewModels"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="1000" d:DesignHeight="600"
             x:Class="PandasBudgettingTool.Views.SpendingView"
             x:CompileBindings="False">

    <Design.DataContext>
        <vm:SpendingViewModel/>
    </Design.DataContext>

    <DockPanel>

        <!-- Header / filter panel -->
        <Border DockPanel.Dock="Top"
                BorderBrush="{DynamicResource SystemBaseLowColor}"
                BorderThickness="0,0,0,1"
                Padding="8,6">
            <StackPanel Orientation="Vertical" Spacing="6">

                <TextBlock TextWrapping="Wrap" MaxWidth="900">
                    <Run Text="Spent:" FontWeight="SemiBold"/>
                    <Run Text="actual spending on this category and its sub-categories over the date range below.  "/>
                    <Run Text="Budget:" FontWeight="SemiBold"/>
                    <Run Text="this category's budget target plus every sub-category's target, recursively.  "/>
                    <Run Text="Remaining:" FontWeight="SemiBold"/>
                    <Run Text="Remaining Money in this category, for the date range"/>
                </TextBlock>

                <StackPanel Orientation="Horizontal" Spacing="8">
                    <TextBlock Text="From:" VerticalAlignment="Center"/>
                    <CalendarDatePicker SelectedDate="{Binding FromDate}" Width="140"/>
                    <TextBlock Text="To:" VerticalAlignment="Center"/>
                    <CalendarDatePicker SelectedDate="{Binding ToDate}" Width="140"/>

                    <Button Content="Apply Filter" Command="{Binding ApplyFilterCommand}" VerticalAlignment="Center"
                            ToolTip.Tip="Reloads and recomputes the figures below for the selected date range"/>
                    <Button Content="Execute Rules" Command="{Binding ExecuteRulesCommand}" VerticalAlignment="Center"
                            ToolTip.Tip="Re-applies all Rules to Transactions in the selected date range, then reloads"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- Net totals -->
        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Spacing="24" Margin="8,8,8,0">
            <StackPanel Orientation="Horizontal" Spacing="6">
                <TextBlock Text="Net Expenses:" FontWeight="SemiBold"/>
                <TextBlock Text="{Binding NetExpenses, StringFormat={}{0:F2}}"/>
            </StackPanel>
            <StackPanel Orientation="Horizontal" Spacing="6">
                <TextBlock Text="Target Expenses:" FontWeight="SemiBold"/>
                <TextBlock Text="{Binding TotalExpenses, StringFormat={}{0:F2}}"/>
            </StackPanel>
            <StackPanel Orientation="Horizontal" Spacing="6">
                <TextBlock Text="Net Cash Flow:" FontWeight="SemiBold"/>
                <TextBlock Text="{Binding NetCashFlow, StringFormat={}{0:F2}}"/>
            </StackPanel>
            <StackPanel Orientation="Horizontal" Spacing="6">
                <TextBlock Text="Target Cash Flow:" FontWeight="SemiBold"/>
                <TextBlock Text="{Binding TotalCashFlow, StringFormat={}{0:F2}}"/>
            </StackPanel>
        </StackPanel>

        <!-- Column headers -->
        <Grid DockPanel.Dock="Top" ColumnDefinitions="260,160,160,160,120" Margin="8,8,8,0">
            <TextBlock Grid.Column="1" Text="Spent"     FontWeight="SemiBold" HorizontalAlignment="Right" Margin="0,0,10,0"/>
            <TextBlock Grid.Column="2" Text="Budget"    FontWeight="SemiBold" HorizontalAlignment="Right" Margin="0,0,10,0"/>
            <TextBlock Grid.Column="3" Text="Remaining" FontWeight="SemiBold" HorizontalAlignment="Right" Margin="0,0,10,0"/>
        </Grid>

        <TreeView ItemsSource="{Binding RootNodes}" Margin="4">
            <TreeView.ItemTemplate>
                <TreeDataTemplate ItemsSource="{Binding Children}">
                    <Grid ColumnDefinitions="260,160,160,160,120">
                        <TextBlock Grid.Column="0" Text="{Binding Name}" VerticalAlignment="Center"/>

                        <TextBlock Grid.Column="1" Text="{Binding SpendingForTerm, StringFormat={}{0:F2}}"
                                   VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,10,0"/>

                        <TextBlock Grid.Column="2" Text="{Binding BudgetTarget, StringFormat={}{0:F2}}"
                                   VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,10,0"/>

                        <TextBlock Grid.Column="3" Text="{Binding Remaining, StringFormat={}{0:F2}}"
                                   FontWeight="SemiBold"
                                   VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,10,0"/>

                        <Button Grid.Column="4" Content="Transactions" Click="OnTransactionsClick" Margin="15,0,0,0"/>
                    </Grid>
                </TreeDataTemplate>
            </TreeView.ItemTemplate>
        </TreeView>

    </DockPanel>

</UserControl>