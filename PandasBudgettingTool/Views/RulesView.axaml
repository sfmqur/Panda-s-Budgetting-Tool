<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:PandasBudgettingTool.ViewModels"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="900" d:DesignHeight="500"
             x:Class="PandasBudgettingTool.Views.RulesView"
             x:CompileBindings="False">

    <Design.DataContext>
        <vm:RulesViewModel/>
    </Design.DataContext>

    <UserControl.DataTemplates>

        <TreeDataTemplate DataType="vm:RuleCategoryTreeNodeViewModel" ItemsSource="{Binding Children}">
            <TextBlock Text="{Binding Name}"
                       FontWeight="SemiBold"
                       VerticalAlignment="Center"
                       Margin="4,4"/>
        </TreeDataTemplate>

        <TreeDataTemplate DataType="vm:RuleTreeNodeViewModel" ItemsSource="{Binding Children}">
            <Border Padding="4,2">
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <TextBox Text="{Binding Name}" Width="180" VerticalAlignment="Center"/>

                    <TextBlock Text="Rank:" VerticalAlignment="Center"/>
                    <NumericUpDown Value="{Binding Rank}" Width="100" FormatString="0" 
                                   Minimum="0" Increment="1"/>

                    <TextBlock Text="Budget Category:" VerticalAlignment="Center"/>
                    <ComboBox ItemsSource="{Binding BudgetCategoryOptions}"
                              SelectedItem="{Binding BudgetCategoryName}"
                              MinWidth="150"/>

                    <TextBlock Text="Rule Category:" VerticalAlignment="Center"/>
                    <ComboBox ItemsSource="{Binding RuleCategoryOptions}"
                              SelectedItem="{Binding RuleCategoryName}"
                              MinWidth="150"/>

                    <Button Content="Conditions" Click="OnConditionsClick"/>
                    <Button Content="Delete" Click="OnDeleteClick"/>
                </StackPanel>
            </Border>
        </TreeDataTemplate>

    </UserControl.DataTemplates>

    <DockPanel>

        <!-- Rule execution panel -->
        <Border DockPanel.Dock="Top"
                BorderBrush="{DynamicResource SystemBaseLowColor}"
                BorderThickness="0,0,0,1"
                Padding="8,6">
            <StackPanel Orientation="Horizontal" Spacing="8">
                <TextBlock Text="From:" VerticalAlignment="Center"/>
                <CalendarDatePicker SelectedDate="{Binding FromDate}" Width="140"/>
                <TextBlock Text="To:" VerticalAlignment="Center"/>
                <CalendarDatePicker SelectedDate="{Binding ToDate}" Width="140"/>

                <TextBlock Text="Budget Category:" VerticalAlignment="Center" Margin="16,0,0,0"/>
                <ComboBox ItemsSource="{Binding BudgetCategoryFilterOptions}"
                          SelectedItem="{Binding SelectedBudgetCategoryFilter}"
                          MinWidth="160"/>

                <Button Content="Execute Rules" Command="{Binding ExecuteRulesCommand}" VerticalAlignment="Center"
                        ToolTip.Tip="Re-applies all Rules to Transactions in the selected date range"/>
            </StackPanel>
        </Border>

        <TreeView ItemsSource="{Binding RootNodes}" Margin="4"/>

    </DockPanel>

</UserControl>