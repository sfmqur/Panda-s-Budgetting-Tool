<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:PandasBudgettingTool.ViewModels"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="600" d:DesignHeight="400"
             x:Class="PandasBudgettingTool.Views.CreateAccountView"
             x:DataType="vm:CreateAccountViewModel">

    <ScrollViewer>
        <StackPanel Margin="24" Spacing="8" MaxWidth="480" HorizontalAlignment="Left">

            <TextBlock Text="Create Account" FontSize="20" FontWeight="SemiBold" Margin="0,0,0,12"/>

            <TextBlock Text="Name *"/>
            <TextBox Text="{Binding Name}" Watermark="Account name"/>

            <CheckBox IsChecked="{Binding IsMinusSignAnExpense}"
                      Content="Minus sign is an expense (standard bank convention)"
                      Margin="0,4,0,0"/>

            <TextBlock Text="Importer Type" Margin="0,4,0,0"/>
            <TextBox Text="{Binding ImporterType}" Watermark="e.g. Csv, Ofx"/>

            <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,20,0,0">
                <Button Content="Create" Command="{Binding CreateCommand}" Width="80"/>
                <Button Content="Clear"  Command="{Binding ClearCommand}"  Width="80"/>
            </StackPanel>

        </StackPanel>
    </ScrollViewer>
</UserControl>