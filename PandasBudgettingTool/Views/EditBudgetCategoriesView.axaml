<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="PandasBudgettingTool.Views.EditBudgetCategoriesView"
             x:CompileBindings="False">

    <DockPanel>

        <!-- Filter panel -->
        <Border DockPanel.Dock="Top"
                BorderBrush="{DynamicResource SystemBaseLowColor}"
                BorderThickness="0,0,0,1"
                Padding="8,6">
            <StackPanel Orientation="Horizontal" Spacing="8">
                <TextBlock Text="Filter by Parent:" VerticalAlignment="Center"/>
                <ComboBox ItemsSource="{Binding ParentFilterOptions}"
                          SelectedItem="{Binding SelectedParentFilter}"
                          MinWidth="180"/>
            </StackPanel>
        </Border>

    <DataGrid ItemsSource="{Binding Categories}"
              AutoGenerateColumns="False"
              CanUserResizeColumns="True"
              GridLinesVisibility="Horizontal"
              Margin="4">

        <DataGrid.Columns>
            <DataGridTextColumn Header="Name"
                                Binding="{Binding Name}"
                                IsReadOnly="True"
                                Width="200" />

            <DataGridTemplateColumn Header="Parent" Width="200">
                <DataGridTemplateColumn.CellTemplate>
                    <DataTemplate>
                        <TextBlock Text="{Binding Parent}"
                                   VerticalAlignment="Center" Margin="12,0"/>
                    </DataTemplate>
                </DataGridTemplateColumn.CellTemplate>
                <DataGridTemplateColumn.CellEditingTemplate>
                    <DataTemplate>
                        <ComboBox ItemsSource="{Binding ParentOptions}"
                                  SelectedItem="{Binding Parent}"
                                  HorizontalAlignment="Stretch"/>
                    </DataTemplate>
                </DataGridTemplateColumn.CellEditingTemplate>
            </DataGridTemplateColumn>

            <DataGridCheckBoxColumn Header="Excluded From Spending Total"
                                    Binding="{Binding IsExcludedFromSpendingTotal}"
                                    Width="250" />

            <DataGridTextColumn Header="Monthly Budget Target"
                                Binding="{Binding BudgetTarget}"
                                Width="300" />

            <DataGridTemplateColumn Header="" Width="180">
                <DataGridTemplateColumn.CellTemplate>
                    <DataTemplate>
                        <StackPanel Orientation="Horizontal" Spacing="4">
                            <Button Content="Rename" Click="OnRenameClick"/>
                            <Button Content="Delete" Click="OnDeleteClick"/>
                        </StackPanel>
                    </DataTemplate>
                </DataGridTemplateColumn.CellTemplate>
            </DataGridTemplateColumn>
        </DataGrid.Columns>

    </DataGrid>

    </DockPanel>

</UserControl>